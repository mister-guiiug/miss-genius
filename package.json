{
  "name": "miss-genius",
  "private": true,
  "license": "MIT",
  "version": "1.0.0",
  "type": "module",
  "description": "Miss Genius — PWA mobile-first de simulation de moyennes scolaires (matières, notes, scénarios, objectifs). Local-first, installable, hors ligne.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:analyze": "cross-env ANALYZE=1 npm run build",
    "preview": "vite preview --base /miss-genius/",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "type-check": "tsc -b",
    "icons": "node scripts/generate-pwa-icons.mjs",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "@mister-guiiug/dev-wpa-config": "^1.3.2",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^3.2.4",
    "cross-env": "^10.1.0",
    "husky": "^9.1.7",
    "jsdom": "^26.0.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.6.2",
    "rollup-plugin-visualizer": "^7.0.1",
    "sharp": "^0.34.5",
    "typescript": "~6.0.2",
    "vite": "^7.0.0",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@rive-app/react-webgl2": "^4.18.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.1",
    "tailwindcss": "^4.2.2",
    "zod": "^3.23.8",
    "zustand": "^5.0.12"
  }
}
